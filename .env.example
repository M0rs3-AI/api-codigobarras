# Copia este archivo a ".env" y completa los valores reales.
# El bridge (Node.js) lee este archivo automaticamente al arrancar;
# no necesitas editar ningun otro archivo del proyecto.

# Token que debe enviar el sistema que consulta el bridge,
# en el header "x-bridge-token". Inventa un valor largo y unico.
BRIDGE_TOKEN=xxxx-xxxx-xxxx-xxxx

# Datos de conexion a SQL Server.
# Si SQL Server corre en el MISMO servidor que el bridge, usa "localhost".
# Si esta en otro servidor de la red, pon su IP o nombre (ej. 192.168.1.50).
SQL_SERVER=localhost
SQL_PORT=1435
SQL_DATABASE=nombre_db
SQL_USER=usuario
SQL_PASSWORD=contrasena

# Nombre del stored procedure a ejecutar. Debe recibir un parametro
# de entrada y retornar un recordset (ver README para el contrato exacto).
SP_NAME=nombre_stored_procedure

# Nombre del parametro de entrada que espera el SP (sin la @). Por defecto
# "barcode" (-> @barcode). Si el SP del cliente ya existe con otro nombre
# de parametro (ej. CodigoBarra -> @CodigoBarra), ponlo aqui en vez de
# modificar el SP.
SP_PARAM_NAME=barcode

# (OPCIONAL) Segundo SP para stock por bodega. Se llama en paralelo con el SP
# principal usando el mismo codigo de barras. Debe retornar filas con las
# columnas Nombre (bodega) y Stock (cantidad). Deja VACIO si este cliente no
# maneja stock por bodega. Ej: INV_Pproductos_GetStock_Codigo_Barra
SP_STOCK_NAME=

# Nombre del parametro del SP de stock (sin la @). Por defecto "CodigoBarra"
# (-> @CodigoBarra). Solo aplica si SP_STOCK_NAME esta configurado.
SP_STOCK_PARAM_NAME=CodigoBarra

# Puerto en el que escucha el bridge. Es el que abres en el firewall
# (Opcion A) o al que apunta el reverse proxy (Opcion B). Ver reverse-proxy.md.
PORT=3001
