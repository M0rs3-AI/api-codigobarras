# Solo para correr la API local fuera de Docker (npm run dev).
# En el stack de Docker Swarm (api.yml) el secreto viene del Docker secret
# 'internal_secret', no de este archivo. DOMAIN/ACME_EMAIL se editan
# directamente en api.yml (lineas marcadas EDITAR).
INTERNAL_SECRET=cambia_este_valor_por_uno_aleatorio_muy_largo
PORT=3001
NODE_ENV=development
