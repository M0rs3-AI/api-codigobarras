# Copia este archivo a ".env" y completa los valores reales.
# El docker-compose (api-codigobarras.yml) lee este archivo automaticamente;
# no necesitas editar ningun otro archivo del proyecto.

# Token que debe enviar el sistema que consulta el bridge,
# en el header "x-bridge-token". Inventa un valor largo y unico.
BRIDGE_TOKEN=xxxx-xxxx-xxxx-xxxx

# Datos de conexion a SQL Server.
# Si SQL Server corre en el MISMO Windows Server que Docker, usa
# "host.docker.internal" en vez de "localhost" (ver README).
SQL_SERVER=localhost
SQL_PORT=1435
SQL_DATABASE=nombre_db
SQL_USER=usuario
SQL_PASSWORD=contrasena

# Nombre del stored procedure a ejecutar. Debe recibir un parametro
# @barcode y retornar un recordset (ver README para el contrato exacto).
SP_NAME=nombre_stored_procedure

# Puerto en el que escucha el bridge DENTRO del contenedor.
PORT=3001

# Puerto que se publica en el host (el que abres en el firewall del cliente).
# Elige uno disponible en ese servidor. Si usas reverse proxy y no publicas
# el puerto directamente, este valor se ignora (ver reverse-proxy.md).
HOST_PORT=3001
