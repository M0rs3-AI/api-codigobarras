# Dependencias
node_modules/

# Build de TypeScript (se genera en el cliente con "npm run build")
dist/
*.tsbuildinfo

# Variables de entorno — CREDENCIALES, nunca subir al repositorio.
# Solo .env.example (plantilla sin secretos) queda versionado.
.env
.env.*
!.env.example

# Servicio node-windows: logs y daemon generados en el servidor del cliente
daemon/

# Instaladores locales de Node (Node se instala en el servidor, no se versiona)
*.msi

# Lockfiles: en el cliente se instala con "npm install" (sin lock versionado)
package-lock.json
pnpm-lock.yaml
pnpm-workspace.yaml

# Logs de depuración
npm-debug.*
yarn-debug.*
yarn-error.*

# OS / varios
.DS_Store
*.pem
*.orig.*
