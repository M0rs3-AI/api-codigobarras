# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# lock file generado por npm (no usamos lock en cliente)
package-lock.json

# node-windows service (logs/daemon generados en el servidor)
daemon/

# typescript
*.tsbuildinfo

app-example

pnpm-lock.yaml
pnpm-workspace.yaml